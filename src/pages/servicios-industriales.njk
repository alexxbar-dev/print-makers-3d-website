<section class="section__outer services-request">
  <div class="section__inner">
    <form action="#" class="services-request__form">
      <div class="services-request__form-header">
        <h3>Solicitar Cotización Integral</h3>
        <p>Cuéntanos sobre tu proyecto y te proporcionaremos una solución completa</p>
      </div>
      <div class="services-request__form-inputs">
        <div class="services-request__form-grid">
          <div class="services-request__form-item">
            <label for="name">Nombre Completo *</label>
            <input type="text" name="name" id="name" placeholder="Tu nombre" required>
          </div>
          <div class="services-request__form-item">
            <label for="company">Empresa</label>
            <input type="text" name="company" id="company" placeholder="Nombre de la empresa">
          </div>
        </div>
        <div class="services-request__form-grid">
          <div class="services-request__form-item">
            <label for="email">Email *</label>
            <input type="email" name="email" id="email" placeholder="Tu@email.com" required>
          </div>
          <div class="services-request__form-item">
            <label for="phone">Teléfono *</label>
            <input type="tel" name="phone" id="phone" placeholder="+52 81 1234-5678" required>
          </div>
        </div>
        <div class="services-request__form-item">
          <label for="services">Servicios de Interés *</label>
          <select name="services" id="services">
            <option value="" disabled selected>¿Qué servicios necesitas?</option>
            <option value="moldes-industriales">Solo Moldes Industriales</option>
            <option value="diseno-3d">Solo Diseño 3D</option>
            <option value="diseno-mas-molde">Diseño 3D + Molde Industrial</option>
            <option value="consultoria-tecnica">Consultoría Técnica</option>
            <option value="otros">Otro (especificar en mensaje)</option>
          </select>
        </div>
        <div class="services-request__form-item">
          <label for="description">Descripción del Proyecto</label>
          <textarea name="description" id="description" placeholder="Describe tu proyecto: tipo de botella, volumen, cantidad, especificaciones especiales..."></textarea>
        </div>
        <div class="services-request__form-itemFile">
          <label for="file" class="services-request__form-labelFile">
            <img src="{{ icons.file_uploadIcon | url }}" alt="" loading="lazy">
          </label>
          <div class="services-request__form-textFile">
            <p class="services-request__form-titleFile">Subir archivos de referencia</p>
            <p class="services-request__form-subtitleFile">Planos, bocetos, imágenes, archivos CAD (opcional)</p>
          </div>
          <input type="file" name="file" id="file" multiple accept=".pdf,.dwg,.dxf,.stl,.obj,.svg,.ai,.psd,.sldprt,.igs,.step,.png,.jpg,.jpeg">
        </div>
        <div class="services-request__form-button">
          <button type="submit">Solicitar Cotización</button>
        </div>
      </div>
    </form>
  </div>
</section>
