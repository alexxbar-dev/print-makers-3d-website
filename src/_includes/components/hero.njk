<section class="hero hero--{{ modifier }}">
  <div class="hero__inner">
    <div class="hero__text hero__text--{{ modifier }}">
      <span class="hero__badge hero__badge--{{ modifier }}">
        {{ hero.badge | safe }}
      </span>
      <h1 class="hero__title">
        {{ hero.title | safe }}
      </h1>
      <p class="hero__description">
        {{ hero.description | safe }}
      </p>

      {% if hero.showbottoms %}
      <div class="buttons-container buttons-container--{{ modifier }}">
        <a href="{{ hero.button1.link | url }}" class="btn orange">{{ hero.button1.text }}</a>
        <a href="{{ hero.button2.link | url }}" class="btn outline">{{ hero.button2.text }}</a>
      </div>
      {% endif %}
    </div>
    {% if hero.showImage%}
    <figure class="hero__image">
      <img src="{{ hero.image.src | url }}" alt="{{ hero.image.alt }}" loading="eager">
    </figure>
    {% endif %}
  </div>
</section>